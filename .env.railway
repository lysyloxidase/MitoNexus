# Railway Environment Variables
MITONEXUS_ENVIRONMENT=production
MITONEXUS_DEBUG=false

# Railway automatically provides these:
# DATABASE_URL - PostgreSQL from Railway plugin
# REDIS_URL - Redis from Railway plugin

# API Configuration
MITONEXUS_CORS_ORIGINS='["https://*.railway.app"]'
MITONEXUS_FRONTEND_URL=https://mitonexus-frontend.railway.app

# Database (will be overridden by Railway)
MITONEXUS_DATABASE_URL=$DATABASE_URL

# Redis (will be overridden by Railway)
MITONEXUS_REDIS_URL=$REDIS_URL

# Neo4j - użyjemy defaults lub własny serwer
MITONEXUS_NEO4J_URI=bolt://localhost:7687
MITONEXUS_NEO4J_USER=neo4j
MITONEXUS_NEO4J_PASSWORD=mitonexus_prod

# Ollama/LLM Models
MITONEXUS_OLLAMA_HOST=http://localhost:11434
MITONEXUS_MODEL_ROUTER=qwen2.5:7b
MITONEXUS_MODEL_PRIMARY=qwen2.5:14b
MITONEXUS_MODEL_REASONER=deepseek-r1:14b
MITONEXUS_MODEL_MEDICAL=meditron:7b
MITONEXUS_MODEL_EMBEDDING=nomic-embed-text

# API Keys (dodaj jak się pojawią)
MITONEXUS_PUBMED_API_KEY=
MITONEXUS_SEMANTIC_SCHOLAR_KEY=
MITONEXUS_LANGFUSE_PUBLIC_KEY=
MITONEXUS_LANGFUSE_SECRET_KEY=
MITONEXUS_LANGFUSE_HOST=

# Report output
MITONEXUS_REPORT_OUTPUT_DIR=/tmp/reports
